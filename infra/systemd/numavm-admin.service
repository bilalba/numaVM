[Unit]
Description=NumaVM Admin Dashboard
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/numavm/admin
ExecStart=/usr/bin/npx serve -s dist -l 4003 --cors
EnvironmentFile=/home/ubuntu/numavm/.env
Restart=on-failure
RestartSec=5
SyslogIdentifier=numavm-admin
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
