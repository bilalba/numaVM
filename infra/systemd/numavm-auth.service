[Unit]
Description=NumaVM Auth Service
After=network.target

[Service]
Type=simple
User=ubuntu
Group=ubuntu
WorkingDirectory=/home/ubuntu/numavm
ExecStart=/usr/bin/node --import tsx auth/server.ts
EnvironmentFile=/home/ubuntu/numavm/.env
Restart=on-failure
RestartSec=5
SyslogIdentifier=numavm-auth
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
