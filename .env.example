# GitHub OAuth App (https://github.com/settings/developers)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth (https://console.cloud.google.com/apis/credentials)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic links (https://resend.com)
RESEND_API_KEY=
EMAIL_FROM=NumaVM <noreply@yourdomain.com>

# JWT session signing (generate with: openssl rand -hex 32)
JWT_SECRET=change-me-to-a-random-string

# Admin user — this email gets is_admin=1 on startup
ADMIN_EMAIL=

# Domain config
BASE_DOMAIN=localhost

# Set to true to bypass OAuth (uses fake dev-user identity)
DEV_MODE=true

# Auth service port
AUTH_PORT=4000

# Control plane
CONTROL_PLANE_PORT=4001
GH_PAT=
DATA_DIR=/data/envs
CADDY_ADMIN_URL=http://localhost:2019
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Stripe billing (https://dashboard.stripe.com/apikeys)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_BASE_PRICE_ID=

# Firecracker
FC_BIN=/opt/firecracker/bin/firecracker
FC_KERNEL=/opt/firecracker/kernel/vmlinux
FC_ROOTFS=/opt/firecracker/rootfs/base.ext4
FC_SOCKET_DIR=/tmp
BRIDGE_IF=br0
VM_GATEWAY=172.16.0.1
VM_VCPU_COUNT=2
VM_MEM_SIZE_MIB=512

# Idle shutdown (15 min default, poll every 30s)
IDLE_TIMEOUT_MS=900000
IDLE_POLL_INTERVAL_MS=30000
