# GitHub OAuth App
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email magic links (Resend)
RESEND_API_KEY=

# JWT session signing
JWT_SECRET=change-me-to-a-random-string

# Domain config
BASE_DOMAIN=localhost

# Auth service port
AUTH_PORT=4000

# Control plane
CONTROL_PLANE_PORT=4001
GH_PAT=
DATA_DIR=/data/envs
CADDY_ADMIN_URL=http://localhost:2019
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Firecracker
FC_BIN=/opt/firecracker/bin/firecracker
FC_KERNEL=/opt/firecracker/kernel/vmlinux
FC_ROOTFS=/opt/firecracker/rootfs/base.ext4
FC_SOCKET_DIR=/tmp
BRIDGE_IF=br0
VM_GATEWAY=172.16.0.1
VM_VCPU_COUNT=2
VM_MEM_SIZE_MIB=512

# Idle shutdown
IDLE_TIMEOUT_MS=900000
IDLE_POLL_INTERVAL_MS=30000
